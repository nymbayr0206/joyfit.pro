// JoyFit MVP v0.1 – Database Foundation
// PostgreSQL with Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentClaimStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum StarType {
  BRONZE
  SILVER
  GOLD
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id             String           @id @default(uuid())
  phone          String           @unique
  firstName      String?
  lastName       String?
  role           UserRole         @default(USER)
  approvalStatus ApprovalStatus   @default(PENDING)
  createdAt      DateTime         @default(now())
  
  pinHash        String?
  sessions       Session[]
  paymentClaims  PaymentClaim[]
  journalEntries JournalEntry[]
  weighIns       WeighIn[]
  starLedger     StarLedger[]
  invitesSent    Invite[]

  @@index([approvalStatus])
  @@index([phone])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([token])
  @@index([userId])
}

model Lead {
  id        String   @id @default(uuid())
  email     String
  phone     String?
  payload   Json
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model PaymentClaim {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    PaymentClaimStatus  @default(SUBMITTED)
  createdAt DateTime            @default(now())
  paidAt    DateTime?
  note      String?

  @@index([status])
  @@index([userId])
}

model JournalEntry {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  mealChecked    Boolean  @default(false)
  mealNote       String?
  waterGlasses   Int      @default(0)
  workoutChecked Boolean  @default(false)
  workoutNote    String?
  sleepChecked   Boolean  @default(false)
  sleepNote      String?
  feelingNote    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model WeighIn {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  weightKg  Decimal  @db.Decimal(5, 2)
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model StarLedger {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      StarType
  kgDelta   Decimal? @db.Decimal(5, 2)
  amountMnt Int?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Invite {
  id            String   @id @default(uuid())
  inviterUserId String
  inviter       User     @relation(fields: [inviterUserId], references: [id], onDelete: Cascade)
  code          String   @unique
  createdAt     DateTime @default(now())

  @@index([inviterUserId])
  @@index([code])
}
